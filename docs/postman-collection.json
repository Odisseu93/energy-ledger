            "description": "Lista faturas filtradas por customer_number usando a variável de coleção."
          },
          "response": []
        },
        {
          "name": "List Invoices (filtered by month)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices?reference_month={{reference_month}}&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices"],
              "query": [
                {
                  "key": "customer_number",
                  "value": "",
                  "disabled": true,
                  "description": "Filtro de cliente desabilitado nesta requisição"
                },
                {
                  "key": "reference_month",
                  "value": "{{reference_month}}",
                  "disabled": false,
                  "description": "Mês de referência (variável de ambiente)"
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": false
                }
              ]
            },
            "description": "Lista faturas filtradas por reference_month. Formato: MMM/AAAA (ex: SET/2024)."
          },
          "response": []
        },
        {
          "name": "List Invoices (customer + month)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/invoices?customer_number={{customer_number}}&reference_month={{reference_month}}&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "invoices"],
              "query": [
                {
                  "key": "customer_number",
                  "value": "{{customer_number}}",
                  "disabled": false,
                  "description": "Número do cliente"
                },
                {
                  "key": "reference_month",
                  "value": "{{reference_month}}",
                  "disabled": false,
                  "description": "Mês de referência"
                },
                {
                  "key": "page",
                  "value": "1",
                  "disabled": false
                },
                {
                  "key": "limit",
                  "value": "20",
                  "disabled": false
                }
              ]
            },
            "description": "Lista faturas combinando filtro de cliente e mês de referência."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
